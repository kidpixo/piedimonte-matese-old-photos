{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GeoJSON FeatureCollection",
  "type": "object",
  "required": ["type", "features"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["FeatureCollection"]
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "geometry", "properties"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["Feature"]
          },
          "geometry": {
            "type": "object",
            "required": ["type", "coordinates"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["Point", "Polygon", "MultiPolygon", "LineString", "MultiLineString", "MultiPoint"]
              },
              "coordinates": {
                "type": "array"
              }
            }
          },
          "properties": {
            "type": "object"
          }
        }
      }
    }
  }
}
